import os
import cv2

def verify_dataset(dataset_path):
    for root, _, files in os.walk(dataset_path):
        for file in files:
            if file.endswith('.jpg') or file.endswith('.png'):
                img_path = os.path.join(root, file)
                img = cv2.imread(img_path)
                if img is None:
                    print(f"Corrupt image: {img_path}")

